  "criticalGaps": {
    "creatorPassword": {
      "severity": "blocker",
      "detail": "Creator entity has no password field. DB schema, entity, and commands all need updating. Required for Spring Security authentication.",
      "files": ["Creator.java", "CreateCreatorCommand.java", "UpdateCreatorCommand.java", "V1.0.2__AddCreatorPassword.sql"]
    },
    "missingDtos": ["TextContentDto", "ImageContentDto", "VideoContentDto", "SlideshowContentDto", "CollectionDto", "ExhibitionDto", "VisitorDto", "VisitHistoryDto"],
    "contentMapperSubclassMappings": {
      "severity": "high",
      "detail": "ContentMapper only has @SubclassMapping for AudioContent. All other subtypes (TextContent, ImageContent, VideoContent, SlideshowContent) are missing."
    },
    "missingMappers": ["CollectionMapper", "VisitorMapper", "VisitHistoryMapper"],
    "missingRestControllerAssemblers": {
      "controllers": ["CreatorController", "CollectionController", "ExhibitionController", "VisitorController", "VisitHistoryController"],
      "modelAssemblers": ["CreatorModelAssembler", "CollectionModelAssembler", "ExhibitionModelAssembler", "VisitorModelAssembler", "VisitHistoryModelAssembler"]
    },
    "contentControllerIncomplete": {
      "severity": "high",
      "detail": "getContent() throws NotImplementedException. Keyset pagination prev/next link logic is broken (uses arithmetic instead of tracking IDs)."
    },
    "noSpringSecurity": "Complete missing: SecurityConfig, CreatorUserDetailsService, CreatorDetails, AdminInitializer",
    "noThymeleaf": "Complete missing: all templates and web controllers (layout.html, CRUD templates, login/register, pool pages, navigation hierarchy)",
    "noRestClientEndpoint": "GET /api/pois/{id}/comments not implemented"
  },

  "entityDetails": {
    "creator": {
      "idType": "Creator.CreatorId (EmbeddedId record)",
      "extended": "AbstractEntity<CreatorId>",
      "fields": ["username", "role (VIEWER|EDITOR|ADMIN)"],
      "missingFields": ["password"]
    },
    "poi": {
      "idType": "PointOfInterest.PointOfInterestId (EmbeddedId record)",
      "extended": "HistoryBase<PointOfInterestId>",
      "fields": ["title (localized map)", "description (localized map)", "content (ManyToMany with Content)"]
    },
    "collection": {
      "idType": "Collection.CollectionId (EmbeddedId record)",
      "extended": "HistoryBase<CollectionId>",
      "fields": ["title (localized map)", "pointsOfInterest (ManyToMany)", "subCollections (OneToMany, self-ref)", "parentCollection (ManyToOne, self-ref)"],
      "note": "@Inheritance JOINED parent of Exhibition"
    },
    "exhibition": {
      "idType": "Collection.CollectionId (inherited)",
      "extended": "Collection",
      "fields": ["languages (ElementCollection Set<String>)"],
      "note": "@PrimaryKeyJoinColumn(name = 'collection_id'), table 'Exhibiton' (typo)"
    },
    "content": {
      "idType": "Long",
      "extended": "HistoryBase<Long>",
      "fields": ["description (localized map)"],
      "note": "Abstract, @Inheritance JOINED, table 'ContentBase'"
    },
    "contentHierarchy": {
      "abstract": ["Content", "MediaContent"],
      "concrete": ["TextContent", "ImageContent", "AudioContent", "VideoContent", "SlideshowContent"]
    },
    "visitor": {
      "idType": "Visitor.VisitorId (EmbeddedId record)",
      "extended": "AbstractEntity<VisitorId>",
      "fields": ["username", "emailAddress", "visitHistories (OneToMany)"]
    },
    "visitHistory": {
      "idType": "VisitHistory.VisitHistoryId (EmbeddedId record)",
      "extended": "AbstractEntity<VisitHistoryId>",
      "fields": ["duration (Duration rich type)", "visitedOn", "pointsOfInterest (ManyToMany)", "visitor (ManyToOne)"],
      "note": "FIXME: Duration rich type caps at 250s, unsuitable for visit durations"
    }
  },

  "modelAssemblerPattern": {
  "package": "com.mfreimueller.art.presentation.assembler",
  "implements": "RepresentationModelAssembler<Entity, EntityModel<Dto>>",
  "keyBehaviors": [
    "Converts entity -> DTO via mapper",
    "Creates self link with .withSelfRel()",
    "Adds .andAffordance(afford(...)) for PUT, PATCH, DELETE",
    "Adds collection link with .withRel('collection')"
  ]
},

